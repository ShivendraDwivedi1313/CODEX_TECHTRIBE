generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER ───────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile          Profile?
  posts            Post[]
  comments         Comment[]
  likes            Like[]
  followers        Follow[]          @relation("following")
  following        Follow[]          @relation("follower")
  sentMessages     Message[]         @relation("sender")
  receivedMessages Message[]         @relation("receiver")
  communityMemberships CommunityMember[]
  notifications    Notification[]    @relation("notificationReceiver")
  sentNotifications Notification[]   @relation("notificationSender")
  codeforcesStat   CodeforcesStat?
  codechefStat     CodechefStat?
  leetcodeStat     LeetcodeStat?
  conversations    ConversationParticipant[]
  chatMessages     ChatMessage[]
  editedCodeSessions ChatCodeSession[]
  sentFriendRequests FriendRequest[] @relation("sentFriendRequests")
  receivedFriendRequests FriendRequest[] @relation("receivedFriendRequests")
  submissions        Submission[]
  questionStats      UserQuestionStats[]

  verifiedCodeforces Boolean @default(false)
  verifiedCodechef   Boolean @default(false)
  verifiedLeetcode   Boolean @default(false)
}

// ─── PROFILE ────────────────────────────────────────────
model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  bio            String?
  headline       String?
  avatarUrl      String?
  coverImageUrl  String?
  college        String?
  company        String?
  location       String?
  website        String?
  githubUrl      String?
  linkedinUrl    String?
  portfolioUrl   String?
  skills         String[] @default([])
  interests      String[] @default([])
  visibility     String   @default("PUBLIC")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
}

// ─── PROJECT ────────────────────────────────────────────
model Project {
  id          String   @id @default(cuid())
  profileId   String
  title       String
  description String?
  techStack   String[] @default([])
  githubUrl   String?
  liveUrl     String?
  imageUrl    String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ─── FOLLOW ─────────────────────────────────────────────
model Follow {
  id          String       @id @default(cuid())
  followerId  String
  followingId String
  status      FollowStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

enum FollowStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── FRIEND REQUEST ─────────────────────────────────────
model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     RequestStatus @default(PENDING)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("sentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("receivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── POST ───────────────────────────────────────────────
model Post {
  id              String    @id @default(cuid())
  authorId        String
  content         String
  title           String?
  imageUrl        String?
  projectLink     String?
  achievement     String?
  isCommunityPost Boolean   @default(false)
  communityId     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  community Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  comments  Comment[]
  likes     Like[]
}

// ─── COMMENT ────────────────────────────────────────────
model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ─── LIKE ───────────────────────────────────────────────
model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ─── COMMUNITY ──────────────────────────────────────────
model Community {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  bannerUrl   String?
  creatorId   String
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  CommunityMember[]
  channels CommunityChannel[]
  posts    Post[]
}

// ─── COMMUNITY MEMBER ───────────────────────────────────
model CommunityMember {
  id          String        @id @default(cuid())
  communityId String
  userId      String
  role        CommunityRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
}

enum CommunityRole {
  MEMBER
  ADMIN
  OWNER
}

// ─── COMMUNITY CHANNEL ──────────────────────────────────
model CommunityChannel {
  id          String   @id @default(cuid())
  communityId String
  name        String
  logo        String?  @default("💬")
  createdAt   DateTime @default(now())

  community      Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  channelMessages ChannelMessage[]
}

// ─── CHANNEL MESSAGE ────────────────────────────────────
model ChannelMessage {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  userName  String
  content   String
  createdAt DateTime @default(now())

  channel CommunityChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

// ─── MESSAGE (DM) ───────────────────────────────────────
model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)
}

// ─── NOTIFICATION ───────────────────────────────────────
model Notification {
  id         String   @id @default(cuid())
  receiverId String
  senderId   String?
  type       String
  message    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  receiver User  @relation("notificationReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender   User? @relation("notificationSender", fields: [senderId], references: [id], onDelete: Cascade)
}

// ─── CODEFORCES STAT ────────────────────────────────────
model CodeforcesStat {
  id              String   @id @default(cuid())
  userId          String   @unique
  handle          String
  solvedQuestions Int      @default(0)
  contests        Int      @default(0)
  maxRating       Int      @default(0)
  currentRating   Int      @default(0)
  rank            String?
  points          Int      @default(0)
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── CODECHEF STAT ──────────────────────────────────────
model CodechefStat {
  id              String   @id @default(cuid())
  userId          String   @unique
  handle          String
  solvedQuestions Int      @default(0)
  contests        Int      @default(0)
  maxRating       Int      @default(0)
  currentRating   Int      @default(0)
  rank            String?
  points          Int      @default(0)
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── LEETCODE STAT ──────────────────────────────────────
model LeetcodeStat {
  id              String   @id @default(cuid())
  userId          String   @unique
  handle          String
  solvedQuestions Int      @default(0)
  contests        Int      @default(0)
  maxRating       Int      @default(0)
  currentRating   Int      @default(0)
  rank            String?
  points          Int      @default(0)
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── DEBUG ROOM (CHAT & CODE) ───────────────────────────
model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     ChatMessage[]
  codeSession  ChatCodeSession?
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           String       @default("TEXT") // TEXT or CODE
  language       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model ChatCodeSession {
  id             String       @id @default(cuid())
  conversationId String       @unique
  code           String       @db.Text
  language       String       @default("javascript")
  lastEditedById String
  updatedAt      DateTime     @updatedAt

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lastEditedBy   User         @relation(fields: [lastEditedById], references: [id], onDelete: Cascade)
}

// ─── QUESTION (Online Judge) ────────────────────────────
enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Verdict {
  ACCEPTED
  WRONG_ANSWER
  COMPILATION_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
}

model Question {
  id                String     @id @default(cuid())
  title             String
  slug              String     @unique
  difficulty        Difficulty
  tags              String[]   @default([])
  statement         String     @db.Text
  inputFormat       String     @db.Text
  outputFormat      String     @db.Text
  constraints       String     @db.Text
  explanation       String?    @db.Text
  visibleSamples    Json       // [{input, output, explanation?}]
  hiddenTestCases   Json       // [{input, expectedOutput}]
  starterCode       Json       // {cpp, python, javascript}
  referenceSolution Json       // {cpp, python, javascript}
  timeLimit         Int        @default(2000) // ms
  memoryLimit       Int        @default(256)  // MB
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  submissions Submission[]
  stats       UserQuestionStats[]
}

model Submission {
  id              String   @id @default(cuid())
  userId          String
  questionId      String
  language        String
  code            String   @db.Text
  verdict         Verdict
  passedTestCases Int      @default(0)
  totalTestCases  Int      @default(0)
  runtime         Int?     // ms
  memory          Int?     // KB
  compileError    String?  @db.Text
  submittedAt     DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model UserQuestionStats {
  id              String   @id @default(cuid())
  userId          String
  questionId      String
  solved          Boolean  @default(false)
  attempts        Int      @default(0)
  bestVerdict     Verdict?
  lastSubmittedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}
  